# Copie este arquivo para .env e preencha os valores.
# cp .env.example .env   (ou: Copy-Item .env.example .env no PowerShell)

# Ollama (local) — obrigatório
# Instale o Ollama (https://ollama.com) e baixe os modelos usados por este agente:
#   ollama pull mistral   # geração (OLLAMA_MODEL)
#   ollama pull phi4      # revisão independente (OLLAMA_REVIEW_MODEL)
#   ollama pull bge-m3    # embeddings (OLLAMA_EMBEDDING_MODEL)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_REVIEW_MODEL=phi4
OLLAMA_EMBEDDING_MODEL=bge-m3

# Jira Cloud — obrigatório apenas para usar --jira / --criar-jira
# Token gerado em id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://seu-site.atlassian.net/
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_EPIC_ISSUE_TYPE_ID=
JIRA_STORY_ISSUE_TYPE_ID=

# Confluence Cloud — obrigatório apenas para usar --confluence
# Usa as mesmas credenciais do Jira (JIRA_EMAIL / JIRA_API_TOKEN) acima.
